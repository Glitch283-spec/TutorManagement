```gitignore
# ==========================
# Dependencies
# ==========================
node_modules/
**/node_modules/

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# Runtime
# ==========================
pids
*.pid
*.seed
*.pid.lock

# ==========================
# Environment Variables
# ==========================
.env
.env.*
!.env.example

# ==========================
# Build Output
# ==========================
dist/
build/
coverage/
.vite/

# ==========================
# Cache
# ==========================
.cache/
.parcel-cache/
.eslintcache

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db
desktop.ini

# ==========================
# IDE
# ==========================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

.idea/

# ==========================
# Temporary Files
# ==========================
tmp/
temp/
*.tmp

# ==========================
# Package Managers
# ==========================
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# ==========================
# React
# ==========================
frontend/dist/
frontend/.vite/

# ==========================
# Express
# ==========================
backend/uploads/
backend/logs/

# ==========================
# Testing
# ==========================
coverage/
.nyc_output/

# ==========================
# Misc
# ==========================
*.local
```
